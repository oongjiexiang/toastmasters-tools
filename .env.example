# ─── Toastmasters Basecamp Progress Fetcher ────────────────────────────────
# Copy this file to .env and fill in your values.

# Your Toastmasters Basecamp session cookie
# How to get it:
#   1. Log in to https://basecamp.toastmasters.org
#   2. Open DevTools (F12) → Application tab → Cookies → basecamp.toastmasters.org
#   3. Find the cookie named "sessionid" and copy its value
BASECAMP_SESSIONID=your-session-id-here

# Club UUID (defaults to NTUA club if not set)
# Found in the API URL: ?club=<this-value>
CLUB_ID=club-guid-here

# Output CSV filename (defaults to results/progress.csv)
OUTPUT_FILE=results/progress.csv

# Output CSV filename for lesson-level detail (defaults to results/details.csv)
DETAIL_OUTPUT_FILE=results/details.csv

# ─── Toastmasters Membership Downloader ─────────────────────────────────────
# Full cookie string for www.toastmasters.org (different site from Basecamp)
# How to get it:
#   1. Log in to https://www.toastmasters.org
#   2. Open DevTools (F12) → Application tab → Cookies → www.toastmasters.org
#   3. Copy each cookie's Name=Value pairs joined by "; " into a single line
#   Example: ARRAffinity=abc123; ASP.NET_SessionId=xyz; .AspNet.Cookies=...; ApiToken=...
TI_COOKIE=your-full-cookie-string-here
