# ─── Toastmasters Basecamp Progress Fetcher ────────────────────────────────
# Copy this file to .env and fill in your values.

# Your Toastmasters Basecamp session cookie
# How to get it:
#   1. Log in to https://basecamp.toastmasters.org
#   2. Open DevTools (F12) → Application tab → Cookies → basecamp.toastmasters.org
#   3. Find the cookie named "sessionid" and copy its value
BASECAMP_SESSIONID=your-session-id-here

# Club UUID (defaults to NTUA club if not set)
# Found in the API URL: ?club=<this-value>
CLUB_ID=club-guid-here

# Output CSV filename (defaults to progress.csv)
OUTPUT_FILE=progress.csv

# Output CSV filename for lesson-level detail (defaults to details.csv)
DETAIL_OUTPUT_FILE=details.csv
